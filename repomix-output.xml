    reservations: '',
  });

  const handleInputChange = (e) => {
    const { name, value } = e.target;
    setEntryData(prev => ({ ...prev, [name]: value }));
  };

  const calculateSPLH = () => {
    const sales = parseFloat(entryData.netSales) || 0;
    const hours = parseFloat(entryData.laborHours) || 0;
    return hours > 0 ? sales / hours : 0;
  };

  useEffect(() => {
    if (isDark) document.documentElement.classList.add('dark');
    else document.documentElement.classList.remove('dark');
  }, [isDark]);
  
  // Initialize with local JSON data and calculate labor percentage immediately
  const [chartData, setChartData] = useState(salesTrendData.map(d => ({
